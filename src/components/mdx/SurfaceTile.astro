---
interface Props {
  href: string;
  title: string;
  kicker?: string;
}

const { href, title, kicker } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const finalHref = href.startsWith("http") ? href : `${base}${href}`;
---

<a class="surface-tile" href={finalHref}>
  {kicker && <span class="surface-tile__kicker">{kicker}</span>}
  <span class="surface-tile__title">{title}</span>
  <span class="surface-tile__body">
    <slot />
  </span>
  <span class="surface-tile__arrow" aria-hidden="true">→</span>
</a>

<style>
  .surface-tile {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    padding: 1.1rem 1.2rem;
    border: 1px solid var(--border);
    border-radius: 6px;
    background: var(--bg);
    color: var(--fg);
    text-decoration: none;
    position: relative;
    transition:
      border-color 120ms ease,
      background 120ms ease,
      transform 120ms ease;
  }
  .surface-tile:hover {
    border-color: var(--accent);
    background: var(--bg-soft);
    text-decoration: none;
  }
  .surface-tile__kicker {
    font-size: 0.72rem;
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--fg-muted);
  }
  .surface-tile__title {
    font-family: var(--font-display);
    font-size: 1.2rem;
    font-weight: 500;
    color: var(--fg);
  }
  .surface-tile__body {
    font-size: 0.92rem;
    color: var(--fg-soft);
    line-height: 1.5;
  }
  .surface-tile__arrow {
    position: absolute;
    top: 1rem;
    right: 1.1rem;
    color: var(--fg-muted);
    transition: color 120ms ease, transform 120ms ease;
  }
  .surface-tile:hover .surface-tile__arrow {
    color: var(--accent);
    transform: translateX(2px);
  }
</style>
