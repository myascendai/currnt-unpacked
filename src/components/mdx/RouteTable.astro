---
export interface Route {
  method?: string;
  path: string;
  handler?: string;
  notes?: string;
}

interface Props {
  routes: Route[];
  caption?: string;
  showMethod?: boolean;
}

const { routes, caption, showMethod = true } = Astro.props;
const methodPalette: Record<string, string> = {
  GET: "var(--color-sage)",
  POST: "var(--color-ochre)",
  PUT: "var(--color-ochre-soft)",
  PATCH: "var(--color-ochre-soft)",
  DELETE: "var(--color-rust)",
  ALL: "var(--fg-muted)",
};
---

<figure class="route-table">
  {caption && <figcaption>{caption}</figcaption>}
  <table>
    <thead>
      <tr>
        {showMethod && <th class="rt-method">Method</th>}
        <th class="rt-path">Path</th>
        <th class="rt-handler">Handler</th>
        <th class="rt-notes">Notes</th>
      </tr>
    </thead>
    <tbody>
      {
        routes.map((r) => (
          <tr>
            {showMethod && (
              <td class="rt-method">
                {r.method && (
                  <span
                    class="rt-method-badge"
                    style={`--m: ${methodPalette[r.method.toUpperCase()] ?? "var(--fg-muted)"}`}
                  >
                    {r.method.toUpperCase()}
                  </span>
                )}
              </td>
            )}
            <td class="rt-path">
              <code>{r.path}</code>
            </td>
            <td class="rt-handler">
              {r.handler && <code>{r.handler}</code>}
            </td>
            <td class="rt-notes">{r.notes ?? ""}</td>
          </tr>
        ))
      }
    </tbody>
  </table>
</figure>

<style>
  .route-table {
    margin: 2rem 0;
  }
  .route-table figcaption {
    font-size: 0.85rem;
    color: var(--fg-muted);
    margin-bottom: 0.5rem;
  }
  .route-table table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.9rem;
  }
  .route-table th,
  .route-table td {
    text-align: left;
    padding: 0.5rem 0.7rem;
    border-bottom: 1px solid var(--border);
    vertical-align: top;
  }
  .route-table th {
    background: var(--bg-soft);
    font-weight: 600;
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--fg-muted);
  }
  .rt-method {
    width: 4.5rem;
  }
  .rt-method-badge {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 600;
    color: var(--m);
    border: 1px solid color-mix(in oklab, var(--m) 50%, transparent);
    border-radius: 3px;
    padding: 0.05rem 0.35rem;
    background: color-mix(in oklab, var(--m) 8%, transparent);
  }
  .rt-path code,
  .rt-handler code {
    font-size: 0.85rem;
    background: transparent;
    border: 0;
    padding: 0;
    color: var(--fg);
  }
  .rt-handler code {
    color: var(--fg-soft);
  }
  .rt-notes {
    color: var(--fg-soft);
  }
</style>
