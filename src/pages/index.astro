---
import BaseLayout from "~/layouts/BaseLayout.astro";
import StatStrip from "~/components/mdx/StatStrip.astro";
import SurfaceTile from "~/components/mdx/SurfaceTile.astro";
import TileGrid from "~/components/mdx/TileGrid.astro";

const stats = [
  { value: "15M", label: "prospects in the CRM" },
  { value: "314", label: "MySQL tables", note: "MySQL 5.5" },
  { value: "140 GB", label: "production data" },
  { value: "62", label: "scheduled cron jobs" },
  { value: "177", label: "email templates" },
  { value: "Dec 2024", label: "codebase frozen" },
];
---

<BaseLayout
  title="currnt-unpacked"
  description="A static archive of the Currnt platform — architecture, history, and post-mortem of a nine-year-old SailsJS monolith frozen in Dec 2024."
  wide
>
  <section class="hero">
    <p class="hero__kicker">Field notes from a frozen platform</p>
    <h1 class="hero__title">
      <span class="hero__title-brand">Currnt,</span> unpacked.
    </h1>
    <p class="hero__lede">
      <strong>Currnt</strong> — originally <em>Expertboards</em>, then{" "}
      <em>Convetit</em> — was a B2B expert-network and market-research platform
      that ran from ~2015 until its codebase was frozen in December 2024. A
      SailsJS monolith on a single application host, a 15M-row outreach
      engine, a 33-controller internal admin, and a homegrown HTTP queue
      keeping the whole thing moving. This site is the archaeological record:
      what was built, how it fit together, what was sunset, and what was
      still planned the day the lights went out.
    </p>
    <StatStrip stats={stats} />
  </section>

  <section class="tour">
    <h2 class="tour__title">Tour the system</h2>
    <p class="tour__lede">
      Start with the bones, or jump straight to a surface that interests you.
    </p>
    <TileGrid columns={2}>
      <SurfaceTile
        href="/architecture"
        title="Architecture"
        kicker="Bones"
      >
        Two hosts, a SailsJS monolith, MySQL 5.5 + Elasticsearch 2.4, Redis,
        and a custom HTTP queue called <code>dispenserd</code> orchestrating
        a Supervisord-managed worker fleet.
      </SurfaceTile>

      <SurfaceTile
        href="/domains"
        title="Product domains"
        kicker="Surface area"
      >
        Six product domains (A–F) plus Corporate, mapped to ~80 user flows
        and a 2,278-line routes file. Each gets its own page with route table
        and headline flow.
      </SurfaceTile>

      <SurfaceTile
        href="/features/crm-engine"
        title="Feature deep-dives"
        kicker="The interesting parts"
      >
        Two standalone tours: the 15M-row CRM and outreach engine, and the
        AI co-facilitator cron that wrote promotional content for a
        privileged author account.
      </SurfaceTile>

      <SurfaceTile
        href="/sunset"
        title="Sunset features"
        kicker="What was let go"
      >
        Eight features that had budget once and then didn&apos;t: an engagement
        marketplace, MetaMask auth, Gnosis Safe payouts, Calendly, Lusha,
        Zoom, an NDA flow, Rev.com transcription.
      </SurfaceTile>

      <SurfaceTile href="/timeline" title="Timeline" kicker="The arc">
        Expertboards (2015) → Convetit (2016) → Currnt (2020) → frozen
        December 2024. Plus the trail of dormant domains.
      </SurfaceTile>

      <SurfaceTile href="/security" title="Security postmortem" kicker="Calibrated">
        A measured look at what an unmaintained nine-year-old stack looks
        like under audit: EOL versions, plaintext secrets, weak password
        hashes, ambient API tokens.
      </SurfaceTile>
    </TileGrid>
  </section>

  <section class="surfaces">
    <h2 class="tour__title">Four ways into the codebase</h2>
    <p class="tour__lede">
      Currnt rendered itself through four distinct surfaces, each with its own
      conventions and audience.
    </p>
    <TileGrid columns={4}>
      <SurfaceTile href="/domains/a-public-web" title="Public web" kicker="A">
        Marketing site, blog, board catalog, signup, login. Sails views
        served from the same monolith.
      </SurfaceTile>
      <SurfaceTile href="/domains/corp-corporate" title="Corporate" kicker="Corp">
        Client-branded sub-experiences for enterprise customers running
        their own advisory boards.
      </SurfaceTile>
      <SurfaceTile href="/domains/b-treehouse" title="Treehouse" kicker="B–F">
        The internal back-office. 33 controllers, 8 pillars, the actual seat
        of operations.
      </SurfaceTile>
      <SurfaceTile href="/domains/g-mobile-api" title="Mobile + Service APIs" kicker="API">
        REST endpoints used by the iOS app and a thin layer of
        service-to-service integrations.
      </SurfaceTile>
    </TileGrid>
  </section>

  <section class="cta">
    <p class="cta__line">
      Codebase frozen. System dormant. Story preserved.
    </p>
  </section>

  <style>
    .hero {
      margin-top: 1rem;
      margin-bottom: 3.5rem;
    }
    .hero__kicker {
      font-family: var(--font-mono);
      font-size: 0.78rem;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--fg-muted);
      margin-bottom: 1rem;
    }
    .hero__title {
      font-family: var(--font-display);
      font-size: clamp(2.8rem, 6vw, 4.4rem);
      line-height: 1;
      letter-spacing: -0.015em;
      margin: 0 0 1.5rem 0;
      font-weight: 600;
      color: var(--navy);
    }
    :global(html.dark) .hero__title {
      color: var(--fg);
    }
    .hero__title-brand {
      color: var(--accent);
    }
    .hero__lede {
      font-size: 1.1rem;
      line-height: 1.6;
      color: var(--fg-soft);
      max-width: 60ch;
      margin: 0 0 1rem 0;
    }
    .hero__lede strong {
      color: var(--fg);
      font-weight: 600;
    }

    .tour,
    .surfaces {
      margin-block: 3.5rem;
    }
    .tour__title {
      font-size: 1.5rem;
      margin: 0 0 0.4rem 0;
    }
    .tour__lede {
      color: var(--fg-soft);
      margin: 0 0 1.2rem 0;
    }

    .cta {
      margin-top: 4rem;
      padding-top: 2rem;
      border-top: 1px solid var(--border);
      text-align: center;
    }
    .cta__line {
      font-family: var(--font-display);
      font-style: italic;
      color: var(--fg-muted);
      font-size: 1.05rem;
      margin: 0;
    }
  </style>
</BaseLayout>
