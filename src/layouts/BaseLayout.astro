---
import "~/styles/global.css";
import ThemeToggle from "~/components/ThemeToggle.svelte";
import SearchTrigger from "~/components/SearchTrigger.svelte";
import SearchModal from "~/components/SearchModal.svelte";

interface Props {
  title: string;
  description?: string;
  wide?: boolean;
}

const { title, description, wide = false } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const pageTitle =
  title === "currnt-unpacked" ? title : `${title} — currnt-unpacked`;

const nav = [
  { href: "/architecture", label: "Architecture" },
  { href: "/domains", label: "Domains" },
  { href: "/features", label: "Features" },
  { href: "/sunset", label: "Sunset" },
  { href: "/timeline", label: "Timeline" },
  { href: "/security", label: "Security" },
];

const footerLinks = [
  { href: "/glossary", label: "Glossary" },
  { href: "/colophon", label: "Colophon" },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    {description && <meta name="description" content={description} />}
    <link rel="icon" type="image/png" sizes="180x180" href={`${base}/brand/favicon-180.png`} />
    <link rel="icon" type="image/png" sizes="167x167" href={`${base}/brand/favicon-167.png`} />
    <link rel="icon" type="image/png" sizes="152x152" href={`${base}/brand/favicon-152.png`} />
    <link rel="icon" type="image/png" sizes="120x120" href={`${base}/brand/favicon-120.png`} />
    <link rel="apple-touch-icon" sizes="180x180" href={`${base}/brand/favicon-180.png`} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link
      rel="preconnect"
      href="https://fonts.gstatic.com"
      crossorigin
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Khand:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <script is:inline>
      (function () {
        try {
          var stored = localStorage.getItem("theme");
          var prefersDark = window.matchMedia(
            "(prefers-color-scheme: dark)",
          ).matches;
          var dark = stored ? stored === "dark" : prefersDark;
          if (dark) document.documentElement.classList.add("dark");
        } catch (e) {}
      })();
    </script>
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <header class="site-header">
      <div class="site-header__inner">
        <a href={`${base}/`} class="brand" aria-label="currnt-unpacked home">
          <img
            class="brand__logo brand__logo--light"
            src={`${base}/brand/currnt-color-logo.png`}
            alt="Currnt"
            width="291"
            height="55"
          />
          <img
            class="brand__logo brand__logo--dark"
            src={`${base}/brand/currnt-white-logo.png`}
            alt="Currnt"
            width="291"
            height="55"
          />
          <span class="brand__suffix">/ unpacked</span>
        </a>
        <nav class="site-nav" aria-label="Primary">
          {
            nav.map((item) => (
              <a href={`${base}${item.href}`} class="site-nav__link">
                {item.label}
              </a>
            ))
          }
        </nav>
        <div class="site-actions">
          <SearchTrigger client:load />
          <ThemeToggle client:load />
        </div>
      </div>
    </header>

    <main
      id="main"
      class={wide ? "prose-wide" : "prose-page"}
      data-pagefind-body
    >
      <slot />
    </main>

    <SearchModal client:idle />

    <footer class="site-footer">
      <div class="site-footer__inner">
        <p>
          A static archive of the <strong>Currnt</strong> platform (frozen Dec 2024).
          Not affiliated with the operating company. The Currnt logo and brand
          marks are used to identify the platform being archived.
        </p>
        <p class="site-footer__meta">
          {
            footerLinks.map((item) => (
              <>
                <a href={`${base}${item.href}`}>{item.label}</a>
                <span> · </span>
              </>
            ))
          }
          Code: <a href="https://github.com/myascendai/currnt-unpacked/blob/main/LICENSE">PolyForm Noncommercial 1.0.0</a> ·
          Content: <a href="https://github.com/myascendai/currnt-unpacked/blob/main/LICENSE-content">CC BY-NC 4.0</a> ·{" "}
          <a href="https://github.com/myascendai/currnt-unpacked">Source</a>
        </p>
      </div>
    </footer>

    <style>
      .skip-link {
        position: absolute;
        left: -9999px;
        top: 0;
      }
      .skip-link:focus {
        left: 1rem;
        top: 1rem;
        background: var(--bg);
        padding: 0.5rem 0.75rem;
        border: 1px solid var(--border);
        z-index: 100;
      }

      .site-header {
        border-bottom: 1px solid var(--border);
        background: color-mix(in oklab, var(--bg) 82%, transparent);
        backdrop-filter: blur(10px) saturate(140%);
        -webkit-backdrop-filter: blur(10px) saturate(140%);
        position: sticky;
        top: 0;
        z-index: 50;
      }

      .site-header__inner {
        max-width: 1100px;
        margin-inline: auto;
        padding: 0.85rem 1.5rem;
        display: flex;
        align-items: center;
        gap: 2rem;
      }

      .brand {
        display: inline-flex;
        align-items: center;
        gap: 0.55rem;
        text-decoration: none;
      }
      .brand:hover {
        text-decoration: none;
      }
      .brand__logo {
        height: 30px;
        width: auto;
        display: block;
      }
      .brand__logo--dark {
        display: none;
      }
      :global(html.dark) .brand__logo--light {
        display: none;
      }
      :global(html.dark) .brand__logo--dark {
        display: block;
      }
      .brand__suffix {
        font-family: var(--font-display);
        font-size: 1.1rem;
        font-weight: 400;
        color: var(--fg-muted);
        letter-spacing: 0.005em;
        line-height: 1;
        padding-top: 4px;
      }

      .site-nav {
        margin-right: auto;
        display: flex;
        gap: 1.3rem;
        font-size: 0.93rem;
      }
      .site-nav__link {
        color: var(--fg-soft);
        text-decoration: none;
        transition: color 120ms ease;
      }
      .site-nav__link:hover {
        color: var(--accent);
        text-decoration: none;
      }

      .site-actions {
        display: flex;
        align-items: center;
        gap: 0.5rem;
      }

      .site-footer {
        border-top: 1px solid var(--border);
        margin-top: 4rem;
        font-size: 0.88rem;
        color: var(--fg-muted);
      }
      .site-footer__inner {
        max-width: 1100px;
        margin-inline: auto;
        padding: 2rem 1.5rem;
      }
      .site-footer__meta {
        margin-top: 0.4em;
      }
      .site-footer p {
        margin: 0;
      }

      @media (max-width: 720px) {
        .site-header__inner {
          gap: 1rem;
          flex-wrap: wrap;
        }
        .site-nav {
          order: 3;
          width: 100%;
          margin-right: 0;
          gap: 0.9rem;
          font-size: 0.85rem;
          flex-wrap: wrap;
        }
        .brand__suffix {
          display: none;
        }
        .brand__logo {
          height: 26px;
        }
        .site-actions {
          margin-left: auto;
        }
      }
    </style>
  </body>
</html>
